  booktitle = {2009 28th {{IEEE International Symposium}} on {{Reliable Distributed Systems}}},
  author = {Leitao, Jo{\~a}o Carlos Antunes and Marques, Jo{\~a}o Pedro Da Silva Ferreira Moura and Pereira, Jos{\'e} Orlando Roque Nascimento and Rodrigues, Lu{\'i}s Eduardo Teixeira},
