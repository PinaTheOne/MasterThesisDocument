@article{Kermarrec2003,
  title = {Probabilistic Reliable Dissemination in Large-Scale Systems},
  author = {Kermarrec, A.-M. and Massoulie, L. and Ganesh, A.J.},
  year = 2003,
  month = mar,
  journal = {IEEE Transactions on Parallel and Distributed Systems},
  volume = {14},
  number = {3},
  pages = {248--258},
  issn = {1045-9219},
  doi = {10.1109/TPDS.2003.1189583},
  urldate = {2026-03-26},
  abstract = {The growth of the Internet raises new challenges for the design of distributed systems and applications. In the context of group communication protocols, gossip-based schemes have attracted interest as they are scalable, easy to deploy, and resilient to network and process failures. However, traditional gossip-based protocols have two major drawbacks: 1) They rely on each peer having knowledge of the global membership and 2) being oblivious to the network topology, they can impose a high load on network links when applied to wide-area settings. In this paper, we provide a theoretical analysis of gossip-based protocols which relates their reliability to key system parameters (system size, failure rates, and number of gossip targets). The results provide guidelines for the design of practical protocols. In particular, they show how reliability can be maintained while alleviating drawback 1) by providing each peer with only a small subset of the total membership information and drawback 2) by organizing members into a hierarchical structure that reflects their proximity according to some network-related metric. We validate the analytical results by simulations and verify that the hierarchical gossip protocol considerably reduces the load on the network compared to the original, nonhierarchical protocol.},
  copyright = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/IEEE.html},
  langid = {english},
  file = {/Users/tomasgabriel/Zotero/storage/42C9L5FI/Kermarrec et al. - 2003 - Probabilistic reliable dissemination in large-scale systems.pdf;/Users/tomasgabriel/Zotero/storage/K6K8HM9V/Kermarrec et al. - 2003 - Probabilistic reliable dissemination in large-scale systems.pdf}
}

@article{Lee2002,
  title = {Packet Loss Probability for Real-Time Wireless Communications},
  author = {Lee, K.K. and Chanson, S.T.},
  year = 2002,
  month = nov,
  journal = {IEEE Transactions on Vehicular Technology},
  volume = {51},
  number = {6},
  pages = {1569--1575},
  issn = {0018-9545},
  doi = {10.1109/TVT.2002.804843},
  urldate = {2026-03-28},
  abstract = {A novel Markov model is constructed to calculate the packet loss probability and the delay distribution of real-time wireless packets. These packets are transmitted through an erroneous channel modeled by a two-state Markov chain. If a packet transmission is not successful, the packet is retransmitted until a delay limit is exceeded. At that time, the packet is discarded and the transmission of the next packet begins. This packet-dropping process has a significant impact on packet loss probability but is seldom considered in other Markov models. Closed-form solutions are obtained, and simplified expressions assuming highly correlated errors and small error probability are derived. Under these conditions, it is found that the packet loss probability is significantly affected by the delay limit and the transition probability of the channel's remaining in the failure state. On the other hand, the probability is almost independent of the arrival rate provided the rate is not close to one.},
  copyright = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/IEEE.html},
  langid = {english},
  file = {/Users/tomasgabriel/Zotero/storage/JD689IHQ/Lee and Chanson - 2002 - Packet loss probability for real-time wireless communications.pdf}
}

